# Database
DATABASE_URL="postgresql://user:password@localhost:5432/marketplace"

# Database connection pooling and timeouts (optional, see recommended values below)
# DB_CONNECTION_LIMIT — Max number of connections in the pool (default: 10)
# Recommended: 10-20 for single instance, up to 50 for high-traffic production
DB_CONNECTION_LIMIT=10

# DB_STATEMENT_TIMEOUT — Max execution time per query in milliseconds (default: 30000)
# Recommended: 30000 (30s) for typical queries; reduce to 10000 for strict SLA
DB_STATEMENT_TIMEOUT=30000

# DB_IDLE_TIMEOUT — Connection idle timeout in milliseconds (default: 30000)
# Recommended: 30000 for most deployments
DB_IDLE_TIMEOUT=30000

# DB_ACQUIRE_TIMEOUT — Max time to acquire a connection from pool in milliseconds (default: 10000)
# Recommended: 10000; increase if experiencing "too many clients" errors under peak load
DB_ACQUIRE_TIMEOUT=10000

MARKETPLACE_CONTRACT_ID=
LAUNCHPAD_CONTRACT_ID=

# Redis Cache
REDIS_URL="redis://localhost:6379"

# Stellar Network
STELLAR_RPC_URL="https://soroban-testnet.stellar.org"
STELLAR_NETWORK="testnet"
# Network passphrase — overrides the default derived from STELLAR_NETWORK.
# Testnet default: "Test SDF Network ; September 2015"
# Mainnet:         "Public Global Stellar Network ; September 2015"
STELLAR_NETWORK_PASSPHRASE=
STELLAR_HORIZON_URL="https://horizon-testnet.stellar.org"

# API
PORT=4000

# CORS — comma-separated list of allowed frontend origins (production only).
# In development (NODE_ENV != production) all origins are permitted.
# Example: CORS_ORIGIN=https://app.ELCARE-HUB.xyz,https://staging.ELCARE-HUB.xyz
CORS_ORIGIN=

# ── Keeper subsystem ──────────────────────────────────────────────────────────
#
# The keeper calls permissionless maintenance entry-points on the marketplace
# contract (expire_listing, finalize_auction, reclaim_offer) automatically.
#
# KEEPER_ENABLED        — Set to "true" to activate the keeper loop.
#                         Default: false (keeper does not run).
KEEPER_ENABLED=false

# KEEPER_SECRET         — Stellar secret key (starts with "S") for the keeper
#                         account.  The account must hold enough XLM to cover
#                         transaction fees.  Required when KEEPER_ENABLED=true.
#                         Generate with: stellar keys generate keeper-account
KEEPER_SECRET=

# KEEPER_DRY_RUN        — Set to "false" to enable real on-chain submissions.
#                         Default: true (simulate and log only; no broadcasts).
KEEPER_DRY_RUN=true

# KEEPER_INTERVAL_MS    — How often (ms) the keeper runs a sweep cycle.
#                         Default: 60000 (1 minute).
KEEPER_INTERVAL_MS=60000

# KEEPER_MAX_ACTIONS_PER_CYCLE
#                       — Maximum maintenance actions per cycle.
#                         Default: 20.
KEEPER_MAX_ACTIONS_PER_CYCLE=20

# KEEPER_MAX_FEE_STROOPS
#                       — Hard cap on fee per transaction (in stroops).
#                         1 XLM = 10_000_000 stroops.  Default: 1_000_000 (~0.1 XLM).
KEEPER_MAX_FEE_STROOPS=1000000

# KEEPER_DAILY_FEE_BUDGET_STROOPS
#                       — Total fees the keeper may spend per calendar day.
#                         Keeper halts and alerts when exhausted.
#                         Default: 10_000_000 (~1 XLM / day).
KEEPER_DAILY_FEE_BUDGET_STROOPS=10000000

# KEEPER_FEE_BUMP_MULTIPLIER
#                       — Fee multiplier applied on each escalation step.
#                         Default: 1.5 (+50% per bump).
KEEPER_FEE_BUMP_MULTIPLIER=1.5

# KEEPER_FEE_BUMP_MAX_RETRIES
#                       — Maximum number of fee-bump attempts before marking
#                         an action as Failed.  Default: 3.
KEEPER_FEE_BUMP_MAX_RETRIES=3

# KEEPER_SUBMIT_TIMEOUT_MS
#                       — Seconds the tx builder uses as the Soroban timeout.
#                         Default: 30000 (30 s).
KEEPER_SUBMIT_TIMEOUT_MS=30000

# KEEPER_POLL_TIMEOUT_MS
#                       — Total time to poll getTransaction before triggering
#                         a fee-bump.  Default: 60000 (60 s).
KEEPER_POLL_TIMEOUT_MS=60000

# KEEPER_POLL_INTERVAL_MS
#                       — Interval between getTransaction polls.
#                         Default: 2000 (2 s).
KEEPER_POLL_INTERVAL_MS=2000

# KEEPER_DISCOVERY_LIMIT
#                       — Max Active listings / Pending offers to check per
#                         discovery sweep (bounds RPC calls).  Default: 200.
KEEPER_DISCOVERY_LIMIT=200

# ── Gap-repair worker ─────────────────────────────────────────────────────────
#
# The gap-repair worker finds Open LedgerGap rows (created whenever the poller
# skips a window or detects a reorg) and runs BackfillJob scans against the
# archival RPC to fill them in.
#
# GAP_REPAIR_ENABLED      — Set to "true" to start the worker inside the main
#                           indexer process.  Default: false.
GAP_REPAIR_ENABLED=false

# ARCHIVAL_STELLAR_RPC_URL — A full-history RPC endpoint used by backfill and
#                            gap-repair.  Defaults to STELLAR_RPC_URL if unset.
ARCHIVAL_STELLAR_RPC_URL=

# GAP_REPAIR_INTERVAL_MS  — How often the worker scans for Open gaps (ms).
#                           Default: 120000 (2 minutes).
GAP_REPAIR_INTERVAL_MS=120000

# GAP_REPAIR_MAX_RETRIES  — How many times to retry a failing gap repair before
#                           marking it Failed.  Default: 3.
GAP_REPAIR_MAX_RETRIES=3

# GAP_REPAIR_BATCH_SIZE   — Ledgers per batch during gap repair.
#                           Defaults to BACKFILL_BATCH_SIZE (5000).
GAP_REPAIR_BATCH_SIZE=5000

# BACKFILL_BATCH_SIZE     — Ledgers per batch for all backfill jobs.  Default: 5000.
BACKFILL_BATCH_SIZE=5000
