// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ListingStatus {
  Active
  Sold
  Cancelled
  Auction
}

enum AuctionStatus {
  Active
  Finalized
  Cancelled
}

enum OfferStatus {
  Pending
  Accepted
  Rejected
  Withdrawn
}

model SyncState {
  id               Int      @id @default(1)
  lastLedger       Int      @default(0)
  lastLedgerHash   String?
  updatedAt        DateTime @updatedAt
}

model Listing {
  listingId       BigInt        @id
  artist          String
  owner           String?
  price           Decimal       @db.Decimal(32, 7)
  currency        String
  collection      String
  nftTokenId      BigInt
  token           String
  status          ListingStatus @default(Active)
  recipients      Json?
  createdAtLedger Int
  updatedAtLedger Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  @@index([artist])
  @@index([status])
  @@index([updatedAtLedger])
  @@index([status, updatedAtLedger])
  @@index([artist, updatedAtLedger])
  @@index([collection])
  @@index([collection, status])
}

model Auction {
  auctionId       BigInt        @id
  creator         String
  collection      String
  nftTokenId      BigInt
  token           String
  reservePrice    Decimal       @db.Decimal(32, 7)
  highestBid      Decimal       @db.Decimal(32, 7)
  highestBidder   String?
  endTime         BigInt
  status          AuctionStatus @default(Active)
  recipients      Json?
  createdAtLedger Int
  updatedAtLedger Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  @@index([updatedAtLedger])
}

model Offer {
  offerId         BigInt      @id
  listingId       BigInt
  offerer         String
  amount          Decimal     @db.Decimal(32, 7)
  token           String
  status          OfferStatus @default(Pending)
  createdAtLedger Int
  updatedAtLedger Int
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  @@index([listingId])
}

model Bid {
  id              Int      @id @default(autoincrement())
  auctionId       BigInt
  bidder          String
  amount          Decimal  @db.Decimal(32, 7)
  ledgerSequence  Int
  createdAt       DateTime @default(now())
  @@index([auctionId])
  @@index([bidder])
  @@index([ledgerSequence])
  @@unique([auctionId, ledgerSequence, bidder])
}

model MarketplaceEvent {
  id              Int      @id @default(autoincrement())
  listingId       BigInt?
  eventType       String   // "LISTING_CREATED", "ARTWORK_SOLD", etc.
  actor           String
  data            Json
  ledgerSequence  Int
  ledgerTimestamp DateTime @default(now())
  @@index([actor])
  @@index([eventType])
  @@index([listingId])
  @@index([ledgerSequence])
  @@index([listingId, ledgerSequence])
  @@unique([listingId, eventType, ledgerSequence])
}

model Collection {
  id              Int      @id @default(autoincrement())
  contractAddress String   @unique
  kind            String   // "normal_721" | "normal_1155" | "lazy_721" | "lazy_1155"
  creator         String
  name            String?
  symbol          String?
  deployedAtLedger Int
  createdAt       DateTime @default(now())
  @@index([creator])
}
