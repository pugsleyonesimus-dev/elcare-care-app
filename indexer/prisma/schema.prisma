// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ListingStatus {
  Active
  Sold
  Cancelled
  Auction
}

enum AuctionStatus {
  Active
  Finalized
  Cancelled
}

enum OfferStatus {
  Pending
  Accepted
  Rejected
  Withdrawn
}

model SyncState {
  id               Int      @id @default(1)
  lastLedger       Int      @default(0)
  lastLedgerHash   String?
  updatedAt        DateTime @updatedAt
}

// ── Dynamic contract registry ─────────────────────────────────────────────────
//
// Each row represents one Soroban contract being tracked by the indexer.
// type: "marketplace" | "launchpad"
// lastLedger/lastLedgerHash track per-contract sync progress independently.

model TrackedContract {
  id               Int      @id @default(autoincrement())
  contractId       String   @unique
  type             String   // "marketplace" | "launchpad"
  label            String   @default("")
  startLedger      Int      @default(0)
  lastLedger       Int      @default(0)
  lastLedgerHash   String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([active])
  @@index([type])
}

model Listing {
  listingId       BigInt        @id
  artist          String
  owner           String?
  price           Decimal       @db.Decimal(32, 7)
  currency        String
  collection      String
  nftTokenId      BigInt
  token           String
  status          ListingStatus @default(Active)
  recipients      Json?
  createdAtLedger Int
  updatedAtLedger Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  @@index([artist])
  @@index([status])
  @@index([updatedAtLedger])
  @@index([status, updatedAtLedger])
  @@index([artist, updatedAtLedger])
  @@index([collection])
  @@index([collection, status])
}

model Auction {
  auctionId       BigInt        @id
  creator         String
  collection      String
  nftTokenId      BigInt
  token           String
  reservePrice    Decimal       @db.Decimal(32, 7)
  highestBid      Decimal       @db.Decimal(32, 7)
  highestBidder   String?
  endTime         BigInt
  status          AuctionStatus @default(Active)
  recipients      Json?
  createdAtLedger Int
  updatedAtLedger Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  @@index([updatedAtLedger])
}

model Offer {
  offerId         BigInt      @id
  listingId       BigInt
  offerer         String
  amount          Decimal     @db.Decimal(32, 7)
  token           String
  status          OfferStatus @default(Pending)
  createdAtLedger Int
  updatedAtLedger Int
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  @@index([listingId])
}

model Bid {
  id              Int      @id @default(autoincrement())
  auctionId       BigInt
  bidder          String
  amount          Decimal  @db.Decimal(32, 7)
  ledgerSequence  Int
  createdAt       DateTime @default(now())
  @@index([auctionId])
  @@index([bidder])
  @@index([ledgerSequence])
  @@unique([auctionId, ledgerSequence, bidder])
}

model MarketplaceEvent {
  id              Int      @id @default(autoincrement())
  listingId       BigInt?
  eventType       String   // "LISTING_CREATED", "ARTWORK_SOLD", etc.
  actor           String
  data            Json
  ledgerSequence  Int
  ledgerTimestamp DateTime @default(now())
  eventHash       String   @unique @default("")  // SHA256(contractId:ledger:txHash:eventIndex)
  contractId      String   @default("")          // source contract address
  @@index([actor])
  @@index([eventType])
  @@index([listingId])
  @@index([ledgerSequence])
  @@index([listingId, ledgerSequence])
  @@index([contractId])
  @@unique([listingId, eventType, ledgerSequence])
}

model Collection {
  id              Int      @id @default(autoincrement())
  contractAddress String   @unique
  kind            String   // "normal_721" | "normal_1155" | "lazy_721" | "lazy_1155"
  creator         String
  name            String?
  symbol          String?
  deployedAtLedger Int
  createdAt       DateTime @default(now())
  @@index([creator])
}

// ── Backfill subsystem ───────────────────────────────────────────────────────
//
// BackfillJob tracks a single bounded historical scan.  Progress is
// check-pointed per batch so a crash can resume from checkpointLedger.
//
// Lifecycle:
//   Pending → Running → Completed
//                     → Failed  (retryable via --resume=<id>)
//   Cancelled         (operator-cancelled before or during run)
//
// advisoryLock: Postgres pg_try_advisory_lock(id) key stored here so two
//               workers cannot claim the same job concurrently.

enum BackfillJobStatus {
  Pending
  Running
  Completed
  Failed
  Cancelled
}

enum LedgerGapSource {
  rpc_window_skip   // poller advanced past the RPC retention window
  reorg             // chain reorg caused a gap
  manual            // operator-created gap for re-processing
}

enum LedgerGapStatus {
  Open       // discovered, not yet repaired
  Repairing  // a BackfillJob is actively working this gap
  Repaired   // fully covered
  Failed     // repair exhausted retries
}

model BackfillJob {
  id                Int               @id @default(autoincrement())
  startLedger       Int
  endLedger         Int
  checkpointLedger  Int               @default(0)  // last batch end written to DB
  status            BackfillJobStatus @default(Pending)
  rpcUrl            String
  error             String?
  totalInserted     Int               @default(0)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // A job may be created to repair a specific gap
  gap               LedgerGap?        @relation(fields: [gapId], references: [id])
  gapId             Int?

  @@index([status])
  @@index([startLedger, endLedger])
  @@index([gapId])
}

model LedgerGap {
  id          Int             @id @default(autoincrement())
  fromLedger  Int
  toLedger    Int
  source      LedgerGapSource
  status      LedgerGapStatus @default(Open)
  error       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // The repair job assigned to cover this gap (null until repair starts)
  repairJob   BackfillJob[]

  @@index([status])
  @@index([fromLedger, toLedger])
  @@unique([fromLedger, toLedger, source])  // prevent duplicate gap rows
}

// ── Keeper subsystem ──────────────────────────────────────────────────────────
//
// Records every maintenance action the keeper attempts so that restarts never
// double-submit a pending on-chain transaction.  The lifecycle is:
//   Pending → Submitted → Succeeded
//                       → Failed (retryable)
//                       → Skipped (permanent — e.g. ListingNotExpired contract revert)
//
// targetType: "ExpireListing" | "FinalizeAuction" | "ReclaimOffer"
// targetId  : the listing_id / auction_id / offer_id (BigInt for parity with the
//             other models)

enum KeeperActionStatus {
  Pending    // Discovered but not yet submitted
  Submitted  // Transaction sent; polling for result
  Succeeded  // getTransaction confirmed success
  Failed     // All retries exhausted; lastError is set
  Skipped    // Permanent contract-level rejection (no resubmission)
}

enum KeeperTargetType {
  ExpireListing
  FinalizeAuction
  ReclaimOffer
}

model KeeperAction {
  id          Int                 @id @default(autoincrement())
  targetType  KeeperTargetType
  targetId    BigInt
  txHash      String?
  status      KeeperActionStatus  @default(Pending)
  attempts    Int                 @default(0)
  lastError   String?
  feePaid     BigInt?             // in stroops; set on Succeeded
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([targetType, targetId])   // idempotency: one live record per target
  @@index([status])
  @@index([targetType, status])
  @@index([updatedAt])
}
